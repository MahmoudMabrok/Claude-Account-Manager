# Server
PORT=3737
HOST=localhost

# Paths
ACCOUNTS_DIR=~/.claude-accounts
BIN_DIR=./bin

# UI Defaults
DEFAULT_LANG=ar
DEFAULT_THEME=dark

# Auto-refresh interval (ms) - how often the UI checks for status updates
AUTO_REFRESH_INTERVAL=30000

# Default model for new accounts (leave empty for Claude default)
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
DEFAULT_MODEL=
